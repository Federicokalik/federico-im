---
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BootScreen from '../components/BootScreen.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;
---

<html lang="it">
	<head>
		<MainHead title={title} description={description} />
		<ClientRouter />
	</head>
	<body>
		<BootScreen />
		<a href="#main" class="skip-link">Skip to content</a>
		<div class="crt-scanlines" aria-hidden="true"></div>

		<Nav />

		<main id="main">
			<slot />
		</main>

		<Footer />

		<script>
			// Live counters anchored to Federico's career start (2016-01-01).
			// Updates any element with data-fk-counter on first paint and on
			// every ClientRouter navigation, so values stay current without a rebuild.
			function updateFkCounters() {
				const start = Date.UTC(2016, 0, 1);
				const now = Date.now();
				const days = Math.floor((now - start) / 86_400_000);
				const today = new Date();
				let years = today.getUTCFullYear() - 2016;
				const md = (today.getUTCMonth() << 5) + today.getUTCDate();
				const startMd = (0 << 5) + 1;
				if (md < startMd) years -= 1;
				const fmtIt = (n: number) => n.toLocaleString('it-IT');

				document.querySelectorAll<HTMLElement>('[data-fk-counter]').forEach((el) => {
					const kind = el.dataset.fkCounter;
					if (kind === 'days-since-2016') el.textContent = fmtIt(days);
					else if (kind === 'years-since-2016') el.textContent = String(years);
					else if (kind === 'years-since-2016-plus') el.textContent = years + '+';
					else if (kind === 'level-since-2016') el.textContent = 'LV ' + String(years).padStart(2, '0');
				});
			}

			updateFkCounters();
			document.addEventListener('astro:page-load', updateFkCounters);
		</script>
	</body>
</html>
