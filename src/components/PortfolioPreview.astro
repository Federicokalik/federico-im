---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const entry = Astro.props.project as any;
const { data } = entry;
const slug: string = (entry.slug ?? entry.id ?? '').toString().replace(/\.(md|mdx)$/i, '');
---

<a class="cartridge" href={`/work/${slug}`} aria-label={`Open project: ${data.title}`}>
	<div class="cartridge__label">
		<h3 class="cartridge__title">{data.title}</h3>
		<div class="cartridge__tags">
			{data.tags?.slice(0, 3).map((tag) => (
				<span class="cartridge__tag">{tag}</span>
			))}
		</div>
	</div>
	<div class="cartridge__sticker">
		<img src={data.img} alt={data.img_alt || data.title} loading="lazy" decoding="async" />
	</div>
	<div class="cartridge__notch" aria-hidden="true"></div>
</a>
