---
interface Props {
	variant?: 'pink' | 'blue' | 'lime' | 'violet';
}

const { variant = 'pink' } = Astro.props;
---

<span class={`fk-pill fk-pill--${variant}`}><slot /></span>

<style>
	.fk-pill {
		display: inline-flex;
		align-items: center;
		gap: var(--sp-2);
		padding: var(--sp-2) var(--sp-3);
		font-family: var(--f-display);
		font-size: var(--fs-xs);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		border: 3px solid currentColor;
		background: var(--c-bg);
		line-height: 1;
		white-space: nowrap;
	}

	.fk-pill--pink   { color: var(--c-pink); }
	.fk-pill--blue   { color: var(--c-blue); }
	.fk-pill--lime   { color: var(--c-lime); }
	.fk-pill--violet { color: var(--c-violet); }
</style>
