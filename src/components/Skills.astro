---
const skills = [
	{
		icon: 'heart',
		title: 'ONE POINT OF CONTACT',
		desc: 'Niente coordinamento tra designer, sviluppatore e consulente SEO. Parli con me, capisco cosa ti serve, faccio. Punto.',
	},
	{
		icon: 'trophy',
		title: 'RESULTS, NOT PROMISES',
		desc: 'Non ti vendo "visibilità" o "engagement". Numeri reali: più contatti, più vendite, più crescita. È l\'unica metrica che conta.',
	},
	{
		icon: 'star',
		title: 'ONE STEP AHEAD',
		desc: 'Il web cambia ogni giorno. Studio, sperimento e applico tecnologie recenti prima che diventino mainstream. Il tuo progetto non nasce gi&agrave; vecchio.',
	},
];
---

<section class="fk-powerups" aria-label="Power-ups">
	{skills.map((s) => (
		<div class="nes-container is-dark is-pink with-title fk-powerup">
			<p class="title">POWER-UP</p>
			<div class="fk-powerup__icon" aria-hidden="true">
				<i class={`nes-icon ${s.icon} is-medium`}></i>
			</div>
			<h3 class="fk-powerup__title">{s.title}</h3>
			<p class="fk-powerup__desc" set:html={s.desc}></p>
		</div>
	))}
</section>

<style>
	.fk-powerups {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--sp-8);
	}

	.fk-powerup {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--sp-3);
		min-height: 300px;
	}

	.fk-powerup__icon {
		display: flex;
		justify-content: center;
		padding: var(--sp-4);
	}

	.fk-powerup__title {
		font-family: var(--f-display);
		font-size: var(--fs-sm);
		color: var(--c-lime);
		text-shadow: var(--glow-lime);
		letter-spacing: 0.06em;
		line-height: var(--lh-snug);
	}

	.fk-powerup__desc {
		font-family: var(--f-body);
		font-size: var(--fs-base);
		color: var(--c-text);
		line-height: var(--lh-loose);
	}

	@media (min-width: 768px) {
		.fk-powerups {
			grid-template-columns: repeat(3, 1fr);
			gap: var(--sp-6);
		}
	}
</style>
