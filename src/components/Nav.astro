---
import AudioToggle from './AudioToggle.astro';

const textLinks: { label: string; href: string; external?: boolean }[] = [
	{ label: 'HOME',       href: '/' },
	{ label: 'BACKGROUND', href: '/background' },
	{ label: 'SCARICA CV', href: 'https://mega.nz/file/mo1xjCpT#mmRS3yXV7Y_srR8hG0i7N8_wCa4A5cfFy1B3Y-PgKko', external: true },
];

const path = Astro.url.pathname;
function isActive(href: string) {
	if (href === '/') return path === '/';
	if (href.startsWith('http')) return false;
	return path === href || path.startsWith(href + '/');
}
---

<nav class="fk-nav" aria-label="Primary navigation">
	<a class="fk-nav__brand" href="/">
		<span aria-hidden="true">&#9654;</span>
		<span class="fk-nav__brand-text">FEDERICO.IM</span>
	</a>

	<button
		type="button"
		id="fk-nav-toggle"
		class="fk-nav__hamburger nes-btn"
		aria-expanded="false"
		aria-controls="fk-nav-menu"
		aria-label="Open menu"
	>
		MENU
	</button>

	<div id="fk-nav-menu" class="fk-nav__menu" data-open="false">
		<ul class="fk-nav__list" role="list">
			{textLinks.map(({ label, href, external }) => (
				<li class={`fk-nav__item ${isActive(href) ? 'is-active' : ''}`}>
					<span class="fk-nav__cursor" aria-hidden="true">&#9654;</span>
					<a
						class="fk-nav__link"
						href={href}
						target={external ? '_blank' : undefined}
						rel={external ? 'noopener noreferrer' : undefined}
						aria-current={isActive(href) ? 'page' : undefined}
					>{label}</a>
				</li>
			))}
		</ul>
		<div class="fk-nav__toggles">
			<AudioToggle />
		</div>
	</div>
</nav>

<script is:inline>
	(function () {
		var btn = document.getElementById('fk-nav-toggle');
		var menu = document.getElementById('fk-nav-menu');
		if (!btn || !menu) return;
		btn.addEventListener('click', function () {
			var open = menu.dataset.open === 'true';
			menu.dataset.open = open ? 'false' : 'true';
			btn.setAttribute('aria-expanded', open ? 'false' : 'true');
			btn.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
			btn.textContent = open ? 'MENU' : 'CLOSE';
		});
		// Close menu on link click (mobile)
		menu.querySelectorAll('a').forEach(function (a) {
			a.addEventListener('click', function () {
				menu.dataset.open = 'false';
				btn.setAttribute('aria-expanded', 'false');
				btn.setAttribute('aria-label', 'Open menu');
				btn.textContent = 'MENU';
			});
		});
	})();
</script>

<style>
	.fk-nav {
		position: sticky;
		top: 0;
		z-index: var(--z-nav);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--sp-4);
		padding: var(--sp-3) var(--wrapper-pad);
		background: var(--c-bg);
		border-bottom: 4px solid var(--c-text);
	}

	.fk-nav__brand {
		font-family: var(--f-display);
		font-size: var(--fs-sm);
		color: var(--c-pink);
		text-decoration: none;
		letter-spacing: 0.1em;
		display: inline-flex;
		align-items: center;
		gap: var(--sp-2);
		text-shadow: var(--glow-pink);
	}

	.fk-nav__brand:hover,
	.fk-nav__brand:focus-visible {
		color: var(--c-blue);
		text-shadow: var(--glow-blue);
	}

	.fk-nav__hamburger {
		font-size: var(--fs-xs);
		padding: 6px 10px;
		min-height: 36px;
	}

	.fk-nav__menu {
		display: none;
	}

	.fk-nav__menu[data-open="true"] {
		display: flex;
		flex-direction: column;
		gap: var(--sp-4);
		position: fixed;
		top: 70px;
		left: 0;
		right: 0;
		bottom: 0;
		padding: var(--sp-6);
		background: var(--c-bg);
		border-top: 4px solid var(--c-text);
		overflow-y: auto;
	}

	.fk-nav__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--sp-3);
	}

	.fk-nav__item {
		display: flex;
		align-items: center;
		gap: var(--sp-3);
		min-height: 44px;
	}

	.fk-nav__cursor {
		font-family: var(--f-display);
		font-size: var(--fs-sm);
		color: var(--c-lime);
		visibility: hidden;
		text-shadow: var(--glow-lime);
		animation: cursor-blink 0.7s steps(2) infinite;
	}

	.fk-nav__item.is-active .fk-nav__cursor {
		visibility: visible;
	}

	.fk-nav__link {
		font-family: var(--f-display);
		font-size: var(--fs-sm);
		color: var(--c-text);
		text-decoration: none;
		letter-spacing: 0.06em;
		padding: var(--sp-2) var(--sp-3);
		transition: color var(--t-fast) ease, text-shadow var(--t-fast) ease;
	}

	.fk-nav__link:hover,
	.fk-nav__link:focus-visible {
		color: var(--c-pink);
		text-shadow: var(--glow-pink);
		outline: none;
	}

	.fk-nav__item.is-active .fk-nav__link {
		color: var(--c-lime);
		text-shadow: var(--glow-lime);
	}

	.fk-nav__toggles {
		display: flex;
		gap: var(--sp-2);
		flex-wrap: wrap;
		padding-top: var(--sp-4);
		border-top: 2px solid var(--c-border);
	}

	@media (min-width: 768px) {
		.fk-nav__hamburger {
			display: none;
		}
		.fk-nav__menu {
			display: flex !important;
			flex-direction: row;
			align-items: center;
			gap: var(--sp-4);
			position: static;
			background: transparent;
			padding: 0;
			border: none;
		}
		.fk-nav__list {
			flex-direction: row;
			gap: var(--sp-2);
		}
		.fk-nav__toggles {
			padding-top: 0;
			border-top: none;
			border-left: 2px solid var(--c-border);
			padding-left: var(--sp-4);
		}
	}

	@media (max-width: 600px) {
		.fk-nav__brand-text {
			font-size: var(--fs-xs);
		}
	}
</style>
