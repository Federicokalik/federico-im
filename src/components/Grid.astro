---
interface Props {
	variant?: 'offset' | 'small';
	min?: string;
}

const { variant, min = '280px' } = Astro.props;
---

<ul class:list={['fk-grid', { 'fk-grid--small': variant === 'small' }]} style={`--min: ${min};`}>
	<slot />
</ul>

<style>
	.fk-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(var(--min, 280px), 100%), 1fr));
		gap: var(--sp-6);
		list-style: none;
		padding: 0;
		margin: 0;
	}

	@media (min-width: 768px) {
		.fk-grid {
			gap: var(--sp-8);
		}
	}

	.fk-grid--small {
		--min: 220px;
		gap: var(--sp-4);
	}
</style>
