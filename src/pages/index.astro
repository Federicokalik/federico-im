---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import Hero from '../components/Hero.astro';
import Skills from '../components/Skills.astro';
import Grid from '../components/Grid.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ContactCTA from '../components/ContactCTA.astro';
import SynthwaveBackground from '../components/SynthwaveBackground.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout>
	<section class="hero-synthwave">
		<SynthwaveBackground />
		<div class="wrapper">
			<div class="fk-home-hero">
				<div class="fk-home-hero__copy">
					<Hero
						align="start"
						typeOn
						title="I'M FEDERICO"
						tagline="Web Designer & Developer dal 2016. Design + codice + SEO in una persona sola — niente template, niente agency overhead."
					>
						<div class="fk-home-hero__roles">
							<span class="fk-pill fk-pill--pink">&#9654; WEB DESIGNER</span>
							<span class="fk-pill fk-pill--blue">&#9654; FULL STACK</span>
							<span class="fk-pill fk-pill--lime">&#9654; AI-NATIVE</span>
						</div>
						<a class="nes-btn is-primary fk-home-hero__cta" href="#powerups">
							<span aria-hidden="true">&#9654;</span> START GAME
						</a>
					</Hero>
				</div>

				<div class="fk-home-hero__portrait">
					<div class="portrait-frame">
						<img class="portrait-sprite" src="/assets/portrait.jpg" alt="Federico Calicchia" width="240" height="300" loading="eager" decoding="async" />
					</div>
					<p class="fk-home-hero__playerlabel">
						<span class="glow-lime">P1</span> &middot; FEDERICO &middot; <span class="glow-blue">LV 09</span>
					</p>
				</div>
			</div>
		</div>
	</section>

	<section id="powerups" class="wrapper fk-section">
		<header class="fk-section__header">
			<h2 class="fk-section__title">POWER-UPS</h2>
			<p class="fk-section__sub">Le tre cose che mi tengono in piedi</p>
		</header>
		<Skills />
	</section>

	<section class="wrapper fk-section">
		<header class="fk-section__header">
			<h2 class="fk-section__title">LEVEL SELECT &mdash; PORTFOLIO</h2>
			<p class="fk-section__sub">Scegli una cartuccia per giocare</p>
		</header>
		<Grid min="300px">
			{projects.map((project) => (
				<li>
					<PortfolioPreview project={project} />
				</li>
			))}
		</Grid>
	</section>

	<ContactCTA />
</BaseLayout>

<style>
	.fk-home-hero {
		display: flex;
		flex-direction: column-reverse;
		gap: var(--sp-10);
		align-items: center;
		padding-block: var(--sp-8);
	}

	.fk-home-hero__copy {
		width: 100%;
	}

	.fk-home-hero__roles {
		display: flex;
		flex-wrap: wrap;
		gap: var(--sp-2);
		margin-top: var(--sp-4);
	}

	.fk-home-hero__cta {
		margin-top: var(--sp-6);
	}

	.fk-home-hero__portrait {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--sp-3);
	}

	.fk-home-hero__playerlabel {
		font-family: var(--f-display);
		font-size: var(--fs-xs);
		color: var(--c-text);
		letter-spacing: 0.08em;
		text-align: center;
		margin: 0;
	}

	@media (min-width: 900px) {
		.fk-home-hero {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: var(--sp-12);
		}

		.fk-home-hero__copy {
			flex: 1.4;
		}

		.fk-home-hero__portrait {
			flex: 1;
			justify-content: center;
		}
	}

	.fk-section {
		padding-block: var(--sp-16);
	}

	.fk-section__header {
		text-align: center;
		margin-bottom: var(--sp-10);
		display: flex;
		flex-direction: column;
		gap: var(--sp-2);
		align-items: center;
	}

	.fk-section__title {
		font-family: var(--f-display);
		font-size: clamp(var(--fs-lg), 3vw, var(--fs-2xl));
		color: var(--c-blue);
		text-shadow: var(--glow-blue);
		letter-spacing: 0.06em;
		line-height: var(--lh-tight);
		margin: 0;
	}

	.fk-section__sub {
		font-family: var(--f-body);
		font-size: var(--fs-md);
		color: var(--c-text-dim);
		margin: 0;
	}
</style>
